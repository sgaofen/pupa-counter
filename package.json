{
  "name": "pupa-counter",
  "version": "0.4.0",
  "description": "Long Lab pupa counter — Electron desktop app with bundled Python inference daemon and the LiDE 300 v3 CNN. Scans, counts, manually edits, and persists pupa detections.",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c cyan,magenta \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.longlab.pupacounter",
    "productName": "Pupa Counter",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "asarUnpack": [
      "electron/scanner/**"
    ],
    "extraResources": [
      {
        "from": "daemon/python-runtime",
        "to": "python-pipeline/python-runtime"
      },
      {
        "from": "daemon/pupa_counter.py",
        "to": "python-pipeline/pupa_counter.py"
      },
      {
        "from": "daemon/pupa_counter_daemon.py",
        "to": "python-pipeline/pupa_counter_daemon.py"
      },
      {
        "from": "daemon/model",
        "to": "python-pipeline/model",
        "filter": [
          "pupa_counter_lide300.pt",
          "peak_filter_clf_lide300.pkl"
        ]
      }
    ],
    "mac": { "category": "public.app-category.developer-tools" },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
